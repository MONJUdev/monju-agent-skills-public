/*.md
  Content-Type: text/markdown; charset=utf-8
  X-Content-Type-Options: nosniff
  Cache-Control: public, max-age=300

/versions/*
  Cache-Control: public, max-age=31536000, immutable

/manifest.json
  Content-Type: application/json; charset=utf-8
  X-Content-Type-Options: nosniff
  Cache-Control: public, max-age=300
